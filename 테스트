# optimize_db.py
import os
from sqlalchemy import create_engine, text
from dotenv import load_dotenv

load_dotenv(override=False)
db_url = os.getenv("DATABASE_URL", "").strip()
if "sslmode=" not in db_url: db_url += "&sslmode=require" if "?" in db_url else "?sslmode=require"

print("🔌 DB에 연결 중...")
# 인덱스 생성 중 DB가 멈추는 것을 방지하기 위해 AUTOCOMMIT 모드 사용
engine = create_engine(db_url, isolation_level="AUTOCOMMIT")

# 수백만 건의 데이터를 0.1초 만에 찾게 해주는 날짜 및 ID 목차(Index)
indexes = [
    "CREATE INDEX CONCURRENTLY IF NOT EXISTS idx_fcd_dt ON fact_campaign_daily(dt);",
    "CREATE INDEX CONCURRENTLY IF NOT EXISTS idx_fkd_dt ON fact_keyword_daily(dt);",
    "CREATE INDEX CONCURRENTLY IF NOT EXISTS idx_fad_dt ON fact_ad_daily(dt);",
    "CREATE INDEX CONCURRENTLY IF NOT EXISTS idx_fcd_cid ON fact_campaign_daily(customer_id);",
    "CREATE INDEX CONCURRENTLY IF NOT EXISTS idx_fkd_cid ON fact_keyword_daily(customer_id);",
    "CREATE INDEX CONCURRENTLY IF NOT EXISTS idx_fad_cid ON fact_ad_daily(customer_id);"
]

with engine.connect() as conn:
    for idx in indexes:
        tbl_name = idx.split(' ON ')[1].replace(';', '')
        print(f"⏳ {tbl_name} 데이터 검색 속도 최적화 중...")
        try:
            conn.execute(text(idx))
            print("   ✅ 초고속 목차 생성 완료!")
        except Exception as e:
            print("   ⚠️ (이미 최적화되어 있거나 건너뜀)")

print("\n🚀 V8 DB 엔진 업그레이드 완료! 대시보드를 새로고침 해보세요. 날아다닐 겁니다 🦅")
